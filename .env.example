# Variables de entorno para el proyecto TFM
# IMPORTANTE: NO subir este archivo a GitHub (ya está en .gitignore)

# ── APIs de Noticias ──────────────────────────────────────
NEWSAPI_KEY=tu_clave_aqui
GNEWS_API_KEY=tu_clave_aqui

# ── Twitter/X API ─────────────────────────────────────────
TWITTER_BEARER_TOKEN=tu_token_aqui
TWITTER_API_KEY=tu_clave_aqui
TWITTER_API_SECRET=tu_secreto_aqui
TWITTER_ACCESS_TOKEN=tu_token_acceso_aqui
TWITTER_ACCESS_TOKEN_SECRET=tu_secreto_acceso_aqui

# ── Reddit API ────────────────────────────────────────────
REDDIT_CLIENT_ID=tu_client_id_aqui
REDDIT_CLIENT_SECRET=tu_secreto_aqui
REDDIT_USER_AGENT=TFM_SentimentBot/1.0

# ── Google Gemini API (IA Generativa) ─────────────────────
GEMINI_API_KEY=tu_clave_aqui

# ── FRED (Federal Reserve) ───────────────────────────────
FRED_API_KEY=tu_clave_aqui

# ── Rutas del proyecto ───────────────────────────────────
PROJECT_ROOT=.
DATA_DIR=./data
MODELS_DIR=./models
REPORTS_DIR=./reports

# ── Configuración General ────────────────────────────────
LOG_LEVEL=INFO
DEVICE=cpu
# Cambiar a 'cuda' si tienes GPU disponible
